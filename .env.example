# ──────────────────────────────────────────
# GitScribe Environment Configuration
# Copy this file to .env and fill in values
# ──────────────────────────────────────────

# GitHub
GITHUB_TOKEN=ghp_your_personal_access_token

# LLM (pluggable — change model without code changes)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=sk-your_openai_api_key

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql://gitscribe:gitscribe@localhost:5432/gitscribe?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Diff Object Storage (MinIO / S3-compatible)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=gitscribe-diffs
MINIO_USE_SSL=false

# App
PORT=3000
NODE_ENV=development
MAX_CONCURRENT_WORKERS=3
WEBHOOK_SECRET=your_webhook_hmac_secret
